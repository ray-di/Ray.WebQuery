<?xml version="1.0"?>
<ruleset name="Ray.WebQuery">
    <description>Ray.WebQuery coding standard</description>

    <rule ref="PSR12"/>
    
    <file>src</file>
    <file>tests</file>

    <exclude-pattern>*/tests/tmp/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/Fake/*</exclude-pattern>
    
    <arg name="colors"/>
    <arg value="p"/>
</ruleset>
